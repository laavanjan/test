# Local development:
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Vercel production / PayTR panel URL:
NEXT_PUBLIC_APP_URL=https://varsapp-live.vercel.app

# Server-side only. Do not expose the service role key in NEXT_PUBLIC_* variables.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=

PAYTR_MERCHANT_ID=paytr-sandbox-merchant-id
PAYTR_MERCHANT_KEY=paytr-sandbox-merchant-key
PAYTR_MERCHANT_SALT=paytr-sandbox-merchant-salt
PAYTR_TEST_MODE=1
PAYTR_DEBUG_ON=1
PAYTR_ENABLE_CARD_STORAGE=0

# Canli admin panelini korumak icin Vercel env'e gir.
# Bos birakilirsa lokal/demo admin acik kalir.
ADMIN_BASIC_USER=
ADMIN_BASIC_PASS=
ADMIN_SESSION_SECRET=

# Localhost testlerinde PayTR dis IP bekler. Vercel'de genelde bos kalabilir.
PAYTR_TEST_USER_IP=

# KolayBi sandbox
KOLAYBI_API_BASE_URL=https://ofis-sandbox-api.kolaybi.com
KOLAYBI_CHANNEL=varsapp
KOLAYBI_API_KEY=
KOLAYBI_AUTO_INVOICE=0
